# Dich Truyen Agent local environment template.
# Copy this file to .env and adjust values for your machine.

# Translation orchestration
# Default: 5. Must be an integer >= 1.
DICH_TRUYEN_TRANSLATION_BATCH_SIZE=5

# Optional export tooling
# EPUBCheck is required for canonical EPUB compliance validation when exporting.
# Example: DICH_TRUYEN_EPUBCHECK_PATH=tools/epubcheck-5.3.0/epubcheck.jar
DICH_TRUYEN_EPUBCHECK_PATH=

# Calibre's ebook-convert is optional; derivative formats are skipped if missing.
# Example Windows path: C:\Program Files\Calibre2\ebook-convert.exe
DICH_TRUYEN_CALIBRE_PATH=
