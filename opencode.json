{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "permission": {
    "bash": {
      "*": "allow",
      "rm -rf /*": "deny",
      "*api.openai.com*": "deny",
      "*openrouter.ai*": "deny",
      "*api.anthropic.com*": "deny",
      "*generativelanguage.googleapis.com*": "deny",
      "*api.deepseek.com*": "deny",
      "*OPENAI_API_KEY*": "deny",
      "*OPENROUTER_API_KEY*": "deny",
      "*ANTHROPIC_API_KEY*": "deny",
      "*GEMINI_API_KEY*": "deny",
      "*DEEPSEEK_API_KEY*": "deny",
      "*import openai*": "deny",
      "*import anthropic*": "deny",
      "*from openai*": "deny",
      "*from anthropic*": "deny"
    },
    "skill": {
      "*": "allow",
      "crawl-book": "deny",
      "translate-book": "deny",
      "check-translation": "deny",
      "export-book": "deny",
      "brainstorming": "deny",
      "writing-plans": "deny",
      "ag-crawl-book": "deny",
      "ag-translate-book": "deny",
      "ag-check-translation": "deny",
      "ag-export-book": "deny",
      "cc-crawl-book": "deny",
      "cc-translate-book": "deny",
      "cc-check-translation": "deny",
      "cc-export-book": "deny",
      "codex-crawl-book": "deny",
      "codex-translate-book": "deny",
      "codex-check-translation": "deny",
      "codex-export-book": "deny"
    },
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "ask",
    "websearch": "ask"
  }
}
