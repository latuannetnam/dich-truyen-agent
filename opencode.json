{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://100.116.54.76:1234/v1",
        "apiKey": "lm-studio"
      },
      "models": {
        "google/gemma-4-12b": {
          "name": "Gemma 4 12B"
        }
      }
    }
  },
  "model": "lmstudio/google/gemma-4-12b",
  "permission": {
    "bash": {
      "*": "allow",
      "rm -rf /*": "deny",
      "*api.openai.com*": "deny",
      "*openrouter.ai*": "deny",
      "*api.anthropic.com*": "deny",
      "*generativelanguage.googleapis.com*": "deny",
      "*api.deepseek.com*": "deny",
      "*OPENAI_API_KEY*": "deny",
      "*OPENROUTER_API_KEY*": "deny",
      "*ANTHROPIC_API_KEY*": "deny",
      "*GEMINI_API_KEY*": "deny",
      "*DEEPSEEK_API_KEY*": "deny",
      "*import openai*": "deny",
      "*import anthropic*": "deny",
      "*from openai*": "deny",
      "*from anthropic*": "deny"
    },
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "ask",
    "websearch": "ask"
  }
}
